.kaggle/
*.env
.env.*

# ─── Streamlit Secrets ────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.log.*

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Testing ──────────────────────────────────────────────────────────────────
